#!/usr/bin/env python3
"""
pgbench runner for TurboAPI+pg.zig.

Drop-in compatible with MagicStack's pgbench suite. Same args, same JSON output.
Starts a TurboAPI server with the query as a db_query route, then benchmarks it
with concurrent HTTP requests (matching pgbench's methodology).

Usage (standalone):
    ./pgbench_zig --pghost=localhost --pgport=5432 --pguser=postgres \
        --concurrency=10 --duration=30 --warmup-time=5 \
        --output-format=json turbopg queries/7-oneplusone.json

Usage (via pgbench orchestrator):
    ./pgbench --benchmark=zig-turbopg ...
"""

import argparse
import asyncio
import json
import socket
import sys
import threading
import time

import numpy as np


def free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


async def worker(session, url, start, duration, timeout_ms):
    """Match pgbench's worker: loop for duration, record per-request latency."""
    queries = 0
    rows = 0
    latency_stats = np.zeros((timeout_ms * 100,))
    min_latency = float("inf")
    max_latency = 0.0

    while time.monotonic() - start < duration:
        req_start = time.monotonic()
        try:
            async with session.get(url) as resp:
                data = await resp.json()
                if isinstance(data, list):
                    rows += len(data)
                else:
                    rows += 1
        except Exception:
            continue
        req_time = round((time.monotonic() - req_start) * 1000 * 100)
        req_time = min(req_time, len(latency_stats) - 1)

        if req_time > max_latency:
            max_latency = req_time
        if req_time < min_latency:
            min_latency = req_time
        latency_stats[req_time] += 1
        queries += 1

    return queries, rows, latency_stats, min_latency, max_latency


async def run_bench(url, concurrency, duration, warmup_time, timeout_ms):
    import aiohttp

    async with aiohttp.ClientSession() as session:
        # Warmup
        if warmup_time > 0:
            start = time.monotonic()
            warmup_tasks = [
                worker(session, url, start, warmup_time, timeout_ms)
                for _ in range(concurrency)
            ]
            await asyncio.gather(*warmup_tasks)

        # Actual benchmark
        start = time.monotonic()
        tasks = [
            worker(session, url, start, duration, timeout_ms)
            for _ in range(concurrency)
        ]
        results = await asyncio.gather(*tasks)
        end = time.monotonic()

    total_duration = end - start
    total_queries = 0
    total_rows = 0
    combined_stats = None
    min_lat = float("inf")
    max_lat = 0.0

    for q, r, stats, mn, mx in results:
        total_queries += q
        total_rows += r
        if combined_stats is None:
            combined_stats = stats
        else:
            combined_stats = np.add(combined_stats, stats)
        if mx > max_lat:
            max_lat = mx
        if mn < min_lat:
            min_lat = mn

    return {
        "queries": total_queries,
        "rows": total_rows,
        "duration": total_duration,
        "min_latency": min_lat,
        "max_latency": max_lat,
        "latency_stats": combined_stats.tolist(),
        "output_format": "json",
    }


def main():
    parser = argparse.ArgumentParser(description="pgbench runner for TurboAPI+pg.zig")
    parser.add_argument("-C", "--concurrency", type=int, default=10)
    parser.add_argument("-D", "--duration", type=int, default=30)
    parser.add_argument("--timeout", default=2, type=int)
    parser.add_argument("--warmup-time", type=int, default=5)
    parser.add_argument("--output-format", default="text", type=str)
    parser.add_argument("--pghost", type=str, default="127.0.0.1")
    parser.add_argument("--pgport", type=int, default=5432)
    parser.add_argument("--pguser", type=str, default="postgres")
    parser.add_argument("driver", help="driver name (ignored, always uses turbopg)")
    parser.add_argument("queryfile", help="JSON file with query")

    args = parser.parse_args()

    # Read query
    with open(args.queryfile) as f:
        querydata = json.load(f)

    query = querydata["query"]
    query_args = querydata.get("args", [])

    # Skip COPY and batch queries (not supported)
    if query.startswith("COPY ") or (query_args and isinstance(query_args[0], dict)):
        sys.exit(3)

    # Build param names for the route
    param_names = [f"p{i}" for i in range(len(query_args))]

    # Build query string with fixed params baked in
    # For pgbench queries, args are always the same, so we bake them into the URL
    qs_parts = [f"{name}={val}" for name, val in zip(param_names, query_args)]
    qs = "&".join(qs_parts)

    # Start TurboAPI server -- redirect stdout to stderr so only JSON goes to stdout
    conn_str = f"postgresql://{args.pguser}@{args.pghost}:{args.pgport}/postgres"

    old_stdout = sys.stdout
    sys.stdout = sys.stderr

    from turboapi import TurboAPI

    app = TurboAPI()
    app.configure_db(conn_str, pool_size=16)

    if param_names:
        @app.db_query("GET", "/bench", sql=query, params=param_names)
        def bench_route():
            pass
    else:
        @app.db_query("GET", "/bench", sql=query)
        def bench_route():
            pass

    port = free_port()
    t = threading.Thread(
        target=lambda: app.run(host="127.0.0.1", port=port), daemon=True
    )
    t.start()
    time.sleep(2)

    sys.stdout = old_stdout

    # Warmup the pool
    import urllib.request
    url = f"http://127.0.0.1:{port}/bench"
    if qs:
        url += f"?{qs}"
    for _ in range(50):
        try:
            urllib.request.urlopen(url, timeout=5).read()
        except Exception:
            pass

    # Run benchmark
    timeout_ms = args.timeout * 1000
    data = asyncio.run(
        run_bench(url, args.concurrency, args.duration, args.warmup_time, timeout_ms)
    )

    print(json.dumps(data))


if __name__ == "__main__":
    main()
